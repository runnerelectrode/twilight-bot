# =====================================================================
# Twilight Tradebot — LIVE MAINNET env template (tightened caps)
#
# Do not copy this verbatim. Read GOING_LIVE.md before flipping the switch.
# Every cap below is intentionally low for the first live week.
# =====================================================================

# ---------- Mode: BOTH must be set to enable live trading ------------
PAPER=0
LIVE_TRADING_CONFIRMED=YES

# ---------- Strategy API ---------------------------------------------
STRATEGY_API_BASE=https://strategy.lunarpunk.xyz
STRATEGY_API_KEY=<your-strategy-api-key>

# ---------- Twilight (relayer-cli) -----------------------------------
NYKS_WALLET_ID=                  # required
NYKS_WALLET_PASSPHRASE=          # required
NETWORK_TYPE=mainnet

# ---------- CEX (mainnet) --------------------------------------------
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=0
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=0

# ---------- Caps (tightened for first live week) ---------------------
MAX_NOTIONAL_USD_PER_INTENT=50
MAX_OPEN_POSITIONS=1
MAX_LEVERAGE=3
MIN_BALANCE_USD_PER_VENUE=100
DAILY_LOSS_STOP_USD=25

# ---------- HTTP API -------------------------------------------------
API_PORT=8787
BIND_PUBLIC=YES                  # required for Railway-public access
API_TOKEN=                       # 32+ random bytes; mandatory when BIND_PUBLIC=YES

# ---------- Runtime --------------------------------------------------
DATA_DIR=/data
LOG_LEVEL=info
