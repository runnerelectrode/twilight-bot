# =====================================================================
# Twilight Tradebot — env template
# Copy to .env and fill in. Default values shown when safe.
# See IMPLEMENTATION_PLAN.md §8 for the safety model.
# =====================================================================

# ---------- Mode (PAPER is default; flipping live needs BOTH vars) ----
PAPER=1
LIVE_TRADING_CONFIRMED=

# ---------- Strategy API (live, no rotation needed for v1) ------------
STRATEGY_API_BASE=https://strategy.lunarpunk.xyz
STRATEGY_API_KEY=<your-strategy-api-key>

# ---------- Twilight (relayer-cli) ------------------------------------
NYKS_WALLET_ID=
NYKS_WALLET_PASSPHRASE=
NYKS_LCD_BASE_URL=https://lcd.twilight.org
NYKS_RPC_BASE_URL=https://rpc.twilight.org
ZKOS_SERVER_URL=https://zkserver.twilight.org
RELAYER_API_RPC_SERVER_URL=https://api.ephemeral.fi/api
PUBLIC_API_RPC_SERVER_URL=https://api.ephemeral.fi/api
RELAYER_PROGRAM_JSON_PATH=/app/relayerprogram.json
CHAIN_ID=nyks
NETWORK_TYPE=mainnet

# Path to the relayer-cli binary. In Docker, install.sh puts it on PATH so leave blank.
# Locally, point at your install (e.g., /Users/<you>/.../tradebot/bin/relayer-cli).
RELAYER_CLI_BIN=

# ---------- CEX execution (ccxt) --------------------------------------
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=0          # 1 to use Binance Futures testnet for paper
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=0            # 1 to use Bybit testnet for paper

# ---------- Caps (safety/guards.ts) -----------------------------------
MAX_NOTIONAL_USD_PER_INTENT=200
MAX_OPEN_POSITIONS=1
MAX_LEVERAGE=5
MIN_BALANCE_USD_PER_VENUE=50
DAILY_LOSS_STOP_USD=50

# ---------- HTTP API --------------------------------------------------
API_PORT=8787
BIND_PUBLIC=             # set to YES to bind 0.0.0.0; requires API_TOKEN
API_TOKEN=               # required when BIND_PUBLIC=YES; ignored otherwise

# ---------- Runtime --------------------------------------------------
DATA_DIR=/data
LOG_LEVEL=info

# ---------- Claude consultation gate (Agent SDK) ---------------------
# The bot calls Claude before executing any live intent. Auth is via the
# Claude Agent SDK which reads OAuth tokens from `~/.claude/` (set up once
# by running `claude login` on the host — uses your Claude Pro/Max
# subscription, no API key needed).
#
# To use API key fallback instead of subscription, set ANTHROPIC_API_KEY.
# To skip consultation entirely (dangerous), set CLAUDE_CONSULT_DISABLED=1.
CLAUDE_CONSULT_MODEL=claude-opus-4-7
CLAUDE_CONSULT_TIMEOUT_MS=20000
# ANTHROPIC_API_KEY=          # only set if not using subscription auth
# CLAUDE_CONSULT_DISABLED=    # set to 1 to bypass — bot becomes fully autonomous
